nextflow.enable.dsl=2
$AUTOSCALE_MEMORY = true
$INITIAL_RUN_TYPE = "gzip"
params.reads = "" //* @input @file @label:"Reads" @optional @description:"To enter BCL folder please enable run_mkfastq option."
params.mate = "pair" //* @dropdown @label:"Mate" @options:"single","pair"
params.genome_build = "" //* @dropdown @label:"Genome Build" @options:"human_hg19_GRCh37_87, human_hg38_gencode_v32_cellranger_v6, human_GRCm38_cellranger_GRCm38-2024-A, mouse_GRCm39_cellranger_GRCm39-2024-A, mouse_mm10_gencode_vm23_cellranger_v6, zebrafish_GRCz11plus_ensembl, zebrafish_GRCz11refSeqUcsc, zebrafish_GRCz11_v4.3.2, zebrafish_GRCz11_v4.3.2_cellranger_v6, d_melanogaster_dm6_refseq_010519_cellranger_v6, d_melanogaster_BDGP6_32_ensembl_105_cellranger_v6, d_melanogaster_flybase_r6_45_cellranger_v6, custom" @description:"If custom is selected, please manually either transcriptome folder or the both genome_source and gtf_source in the system inputs section. If you entered custom genome_source and gtf_source then please enable the 'Download Genomics Sources' and 'Run mkref' options."
params.run_mkfastq = "no" //* @dropdown @label:"Run mkfastq" @options:"yes","no" @show_settings:"mkfastq_prep,mkfastq" @description:"If you have a BCL folder as input, turn this module on instead of entering Reads."

params.run_FastQC =  "yes"  //* @dropdown @label:"Run FastQC" @options:"yes","no" @description:"Provides quality control checks on raw sequence data. <a target="_blank" href="https://www.bioinformatics.babraham.ac.uk/projects/fastqc/">FastQC Documentation Link</a>"
params.run_Cell_Ranger_Count = "yes" //* @dropdown @label:"Run Cellranger Count" @options:"yes","no" @show_settings:"Cell_Ranger_Count"
params.run_scRNA_Analysis = "yes" //* @dropdown @label:"Run scRNA-seq Analysis Module" @options:"yes","no" @show_settings:"params.Metadata, Load_Data_and_QC_h5,PCA_and_Batch_Effect_Correction,Clustering_and_Find_Markers,SCEtoLOOM,params.run_annotation,params.run_tcr_analysis" @description:"Performs downstream analysis such as QC, dimensionality reduction, clustering, and finding cluster markers."

params.Metadata = "" //* @input @optional @single_file @editor:{"collection_autofill":{"input_name":"reads", "column":"1"}, "type":"spreadsheet","filename":"metadata.tsv","separator":"tab","default":[["Sample","Condition"]]}
params.run_velocity = "no" //* @dropdown @label:"Run RNA Velocity Module" @options:"yes","no" @description:"Runs RNA velocity module. This module requires that the 'scRNA Analysis Module' is turned on." @show_settings:"params.bam,params.barcodes,params.mask_gtf"
params.run_pySCENIC = "no" //* @dropdown @label:"Run pySCENIC" @options:"yes","no" @description:"Runs the pySCENIC tool. This module requires that the 'scRNA Analysis Module' is turned on." @show_settings:"pySCENIC"
params.run_cellchat2 = "no" //* @dropdown @label:"Run CellChat2 Module" @options:"yes","no" @description:"Run CellChat2 tool?" @show_settings:"params.ident,params.db_type,params.smooth,params.average_method,params.trim,params.min_cells,params.cell_groups,params.sources_use,params.targets_use"
params.run_annotation = "yes" //* @dropdown @label:"Run Automated Cell-Type Annotation" @options:"yes","no" @show_settings:"sc_annotation"

params.run_mkref = "no" //* @dropdown @label:"Run mkref" @options:"yes","no" @show_settings:"Cell_Ranger_mkref" @description:"This step builds reference for cell ranger. If you want to use custom genome or gtf, please select yes and enter genome_source and gtf_source in system inputs."

params.run_Download_Genomic_Sources = "no" //* @dropdown @label:"Download Genomic Sources" @options:"yes","no" @show_settings:"params.replace_geneID_with_geneName, params.gtf_type"  @description:"Please enable if you entered custom genome_source and gtf_source."
params.add_sequences_to_reference = "no" //* @dropdown @label:"Add Sequences to Reference" @options:"yes","no" @show_settings:"params.custom_additional_gtf, params.custom_additional_genome, params, Add_chromosomes_to_genome_gtf" @description:"Please enable 'Download Genomic Sources' option and 'Run mkref' options to incorporate custom fasta/gtf files into the genome."
params.custom_additional_genome = "" //* @input @label:"Custom Additional Fasta File (optional)" @optional @single_file @description:"Custom fasta file to use with the main genome file."
params.custom_additional_gtf = "" //* @input @label:"Custom Additional GTF File (optional)" @optional @single_file @description:"Additional gtf file to use with the main gtf file."

params.bam = "" //* @input @file @label:"Bam File" @optional @description:"Only required if run_Cell_Ranger_Count is off."
params.barcodes = "" //* @input @file @label:"Barcodes file (barcodes.tsv.gz) from cellranger output." @optional @description:"Only required if run_Cell_Ranger_Count is off."
params.mask_gtf = "" //* @input @optional @single_file @description:".gtf file containing intervals to mask."

params.Ambient_RNA_Removal = "no" //* @dropdown @options:"yes","no" @description:"Whether to remove ambient RNA from the Cellranger results" 
params.replace_geneID_with_geneName = "no" //* @dropdown @options:"yes,no" @description:"Replaces gene_id attribute with gene_name attribute in the gtf file"
params.gtf_type='ensembl' //*  @dropdown @options:"ensembl","gencode","ncbi"
params.species='human' //*  @dropdown @label:"Species name" @options:"human","mouse","d_melanogaster","zebrafish"

// Pipeline Defaults
params.convert_gtf_to_bed = "no"

process {
    withLabel: scrna_seurat {
        container = 'quay.io/ummsbiocore/scrna_seurat:2.0'
    }
}

// process {
//     errorStrategy = 'retry'
//     maxRetries    = 2
// }